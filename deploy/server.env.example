# =============================================================================
# 服务器端生产环境配置模板
# 用法：复制为 deploy/server.env，按需修改后由 deploy.ps1 自动上传为远程根目录 .env
# 注意：本文件不含真实密钥，仅作模板；deploy/server.env 已被 .gitignore 排除
# =============================================================================

# ===== App =====
APP_ENV=prod
APP_DEBUG=false
# 生产环境务必替换为随机长字符串（>= 32 字节）
APP_SECRET_KEY=please-change-me-to-a-random-32bytes-secret

# ===== PostgreSQL =====
# 容器内通信走 docker 网络（postgres:5432），docker-compose.yml 中已覆盖 DATABASE_URL
# 这里的 POSTGRES_* 用于 postgres 容器初始化 + compose 变量插值
POSTGRES_DB=smartadmin
POSTGRES_USER=smartadmin
# 生产环境务必替换为强密码
POSTGRES_PASSWORD=please-change-me-strong-password

# DATABASE_URL 会被 docker-compose.yml 中的 environment 覆盖，但保留一份方便容器外调试
DATABASE_URL=postgresql+asyncpg://smartadmin:please-change-me-strong-password@postgres:5432/smartadmin

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== 火山方舟（Volcengine Ark） =====
ARK_API_KEY=replace-with-real-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=deepseek-v3-2-251201
ARK_VISION_MODEL=doubao-seed-1-6-flash-250828
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215
ARK_EMBEDDING_DIM=2048

# ===== Tavily（团建策划师搜索） =====
TAVILY_API_KEY=replace-with-real-tavily-api-key

# ===== 钉钉 访客通知（选填，留空则静默） =====
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# ===== CORS / Frontend =====
# 服务器对外访问地址（nginx 暴露端口 8081）
CORS_ORIGINS=http://192.168.10.130:8081,http://localhost:8081
